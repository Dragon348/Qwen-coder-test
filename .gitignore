```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.ts
*.tsx
*.css

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled/Binary
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Coverage
coverage/
htmlcov/
.coverage

# Caches
.mypy_cache/
.pytest_cache/
.gradle/
target/

# System
.DS_Store
Thumbs.db
```